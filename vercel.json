{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/login", "destination": "/dist/index.html" },
    { "source": "/login", "destination": "/frontend/dist/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/dist/index.html" },
    { "source": "/dashboard", "destination": "/frontend/dist/index.html" },
    { "source": "/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/dist/index.html" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ]
}
