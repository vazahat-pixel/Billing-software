# Production template — copy to backend/.env on the VPS
# Do NOT commit real secrets.

NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/billing_software
JWT_SECRET=REPLACE_WITH_40_CHAR_RANDOM_SECRET_MINIMUM_32
JWT_ACCESS_EXPIRES=8h
JWT_REFRESH_DAYS=30
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=40
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
LOG_LEVEL=info
