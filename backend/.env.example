# Backend environment (copy to backend/.env)

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/billing_software
JWT_SECRET=replace-with-at-least-32-char-random-secret
JWT_ACCESS_EXPIRES=8h
JWT_REFRESH_DAYS=30
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=40
MONGO_MAX_POOL=20
MONGO_MIN_POOL=2
MONGO_SLOW_MS=200
# MONGO_DEBUG=true
# REDIS_URL=redis://localhost:6379
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
# BACKUP_ENCRYPTION_KEY=separate-from-jwt-recommended
JOB_POLL_MS=5000
JSON_BODY_LIMIT=2mb
LOG_LEVEL=info
